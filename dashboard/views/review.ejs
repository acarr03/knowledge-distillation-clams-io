<%- include('layout', { body: `
<div id="review-page" data-id="${id}">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <a href="/interactions" class="text-gray-500 hover:text-gray-300 text-sm">&larr; Back</a>
      <h1 class="text-2xl font-bold">Interaction #<span id="r-id">${id}</span></h1>
      <span id="r-status-badges" class="flex gap-2"></span>
    </div>
    <div class="flex gap-2">
      <button id="btn-prev" onclick="navReview(-1)" class="bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-1.5 rounded text-sm">Prev</button>
      <button id="btn-next" onclick="navReview(1)" class="bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-1.5 rounded text-sm">Next</button>
    </div>
  </div>

  <!-- Metadata row -->
  <div id="r-meta" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3 mb-6 text-sm"></div>

  <!-- Query -->
  <div class="bg-gray-900 rounded-lg border border-gray-800 p-5 mb-4">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">User Query</h2>
    <div id="r-query" class="text-gray-200 whitespace-pre-wrap"></div>
  </div>

  <!-- Context (collapsible) -->
  <details class="bg-gray-900 rounded-lg border border-gray-800 mb-4">
    <summary class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide cursor-pointer hover:text-gray-400">Context (RAG / Material / Compliance)</summary>
    <div class="px-5 pb-4 space-y-3">
      <div>
        <div class="text-xs text-gray-600 mb-1">RAG Context</div>
        <pre id="r-rag" class="text-xs text-gray-400 whitespace-pre-wrap max-h-48 overflow-auto">None</pre>
      </div>
      <div>
        <div class="text-xs text-gray-600 mb-1">Material Context</div>
        <pre id="r-material" class="text-xs text-gray-400 whitespace-pre-wrap max-h-48 overflow-auto">None</pre>
      </div>
      <div>
        <div class="text-xs text-gray-600 mb-1">Compliance Context</div>
        <pre id="r-compliance" class="text-xs text-gray-400 whitespace-pre-wrap max-h-48 overflow-auto">None</pre>
      </div>
    </div>
  </details>

  <!-- Sonnet Response -->
  <div class="bg-gray-900 rounded-lg border border-gray-800 p-5 mb-4">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Sonnet Response</h2>
    <div id="r-response" class="text-gray-200 whitespace-pre-wrap max-h-[500px] overflow-auto"></div>
  </div>

  <!-- Review form -->
  <div class="bg-gray-900 rounded-lg border border-clams-700/30 p-5">
    <h2 class="text-xs font-semibold text-clams-500 uppercase tracking-wide mb-4">Engineer Review</h2>

    <div class="mb-4">
      <label class="block text-xs text-gray-500 mb-1">Edited Response (optional — leave blank to keep Sonnet original)</label>
      <textarea id="r-edited" rows="8" class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded px-3 py-2 text-sm font-mono" placeholder="Paste or type your edited response here..."></textarea>
    </div>

    <div class="mb-4">
      <label class="block text-xs text-gray-500 mb-1">Review Notes</label>
      <textarea id="r-notes" rows="3" class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded px-3 py-2 text-sm" placeholder="Notes on quality, accuracy, what was changed..."></textarea>
    </div>

    <div class="flex gap-3">
      <button onclick="submitReview(true)" class="bg-green-700 hover:bg-green-600 text-white px-5 py-2 rounded text-sm font-medium">Approve</button>
      <button onclick="submitReview(false)" class="bg-red-700 hover:bg-red-600 text-white px-5 py-2 rounded text-sm font-medium">Reject</button>
    </div>

    <div id="r-toast" class="mt-3 text-sm hidden"></div>
  </div>
</div>
` }) %>
