<%- include('layout', { body: `
<div id="interactions-page">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Interactions</h1>
    <span id="result-count" class="text-sm text-gray-500"></span>
  </div>

  <!-- Filter bar -->
  <div class="bg-gray-900 rounded-lg p-4 border border-gray-800 mb-6 flex flex-wrap gap-3 items-end">
    <div>
      <label class="block text-xs text-gray-500 mb-1">Category</label>
      <select id="f-category" class="bg-gray-800 border border-gray-700 text-gray-200 rounded px-2 py-1.5 text-sm">
        <option value="">All</option>
        <option value="material_lookup">material_lookup</option>
        <option value="comparison">comparison</option>
        <option value="multi_constraint_selection">multi_constraint_selection</option>
        <option value="calculation">calculation</option>
        <option value="compliance_check">compliance_check</option>
        <option value="document_search">document_search</option>
        <option value="general_engineering">general_engineering</option>
        <option value="unit_conversion">unit_conversion</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Reviewed</label>
      <select id="f-reviewed" class="bg-gray-800 border border-gray-700 text-gray-200 rounded px-2 py-1.5 text-sm">
        <option value="">All</option>
        <option value="true">Yes</option>
        <option value="false">No</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Approved</label>
      <select id="f-approved" class="bg-gray-800 border border-gray-700 text-gray-200 rounded px-2 py-1.5 text-sm">
        <option value="">All</option>
        <option value="true">Yes</option>
        <option value="false">No</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Complexity</label>
      <select id="f-complexity" class="bg-gray-800 border border-gray-700 text-gray-200 rounded px-2 py-1.5 text-sm">
        <option value="">All</option>
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3">3</option>
        <option value="4">4</option>
        <option value="5">5</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">From</label>
      <input id="f-from" type="date" class="bg-gray-800 border border-gray-700 text-gray-200 rounded px-2 py-1.5 text-sm">
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">To</label>
      <input id="f-to" type="date" class="bg-gray-800 border border-gray-700 text-gray-200 rounded px-2 py-1.5 text-sm">
    </div>
    <div class="flex-1 min-w-[200px]">
      <label class="block text-xs text-gray-500 mb-1">Search query</label>
      <input id="f-search" type="text" placeholder="Search..." class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded px-2 py-1.5 text-sm">
    </div>
    <button onclick="loadInteractions(1)" class="bg-clams-700 hover:bg-clams-600 text-white px-4 py-1.5 rounded text-sm">Filter</button>
  </div>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-gray-500 border-b border-gray-800">
          <th class="pb-2 pr-3">ID</th>
          <th class="pb-2 pr-3">Query</th>
          <th class="pb-2 pr-3">Category</th>
          <th class="pb-2 pr-3">Cmplx</th>
          <th class="pb-2 pr-3">Status</th>
          <th class="pb-2 pr-3">Cost</th>
          <th class="pb-2">Date</th>
        </tr>
      </thead>
      <tbody id="interactions-body" class="divide-y divide-gray-800/50"></tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="mt-4 flex items-center justify-center gap-2"></div>
</div>
` }) %>
