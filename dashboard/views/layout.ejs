<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CLAMS Curation Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            clams: { 500: '#00ff88', 600: '#00cc6a', 700: '#009950' }
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    .badge { @apply inline-flex items-center px-2 py-0.5 rounded text-xs font-medium; }
  </style>
</head>
<body class="bg-gray-950 text-gray-200 min-h-screen">
  <nav class="bg-gray-900 border-b border-gray-800 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="text-clams-500 font-bold text-lg tracking-tight">CLAMS Curation</a>
      <a href="/" class="text-gray-400 hover:text-gray-200 text-sm">Overview</a>
      <a href="/interactions" class="text-gray-400 hover:text-gray-200 text-sm">Interactions</a>
    </div>
    <div class="flex items-center gap-3">
      <select id="org-selector" class="bg-gray-800 border border-gray-700 text-gray-300 rounded px-2 py-1 text-xs">
        <option value="">All Organizations</option>
      </select>
      <a id="export-link" href="/api/export/training" class="text-xs bg-clams-700 hover:bg-clams-600 text-white px-3 py-1.5 rounded">Export JSONL</a>
    </div>
  </nav>
  <main class="max-w-7xl mx-auto px-6 py-8">
    <%- body %>
  </main>
  <script src="/app.js"></script>
</body>
</html>
